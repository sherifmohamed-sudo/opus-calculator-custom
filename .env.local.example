# Supabase — get these from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-side only — NEVER expose to the browser or commit this file
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App URL (change to production URL on Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Main Opus Pricing Calculator (same origin as /api/save-delivery-quote). No trailing slash.
# Used to save delivery quotes into the shared `quotes` table and deep-link My Quotes / admin.
NEXT_PUBLIC_MAIN_CALC_ORIGIN=http://localhost:5173
